rules_version = '2';

// ========================================
// REGLAS DE FIREBASE STORAGE - PARA TESTING
// ========================================
// IMPORTANTE: Estas reglas son PERMISIVAS para testear.
// NO uses esto en producción.
// ========================================

service firebase.storage {
  match /b/{bucket}/o {
    
    // Carpeta de testing - permite todo
    match /test_videos/{videoId} {
      // Cualquiera puede leer
      allow read: if true;
      
      // Cualquiera puede escribir
      allow write: if true;
    }
    
    // Carpeta de tu app principal (si existe)
    match /videos/{videoId} {
      // Leer: todos
      allow read: if true;
      
      // Escribir: validar que sea video y tamaño < 100MB
      allow create: if 
        request.resource.contentType.matches('video/.*') &&
        request.resource.size < 100 * 1024 * 1024;
      
      // No permitir actualizar o borrar
      allow update, delete: if false;
    }
    
    // Bloquear acceso a cualquier otro lugar
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

// ========================================
// CÓMO APLICAR ESTAS REGLAS:
// ========================================
// 1. Andá a: https://console.firebase.google.com/
// 2. Seleccioná tu proyecto
// 3. Build → Storage
// 4. Pestaña "Rules"
// 5. Copiá y pegá TODO este contenido
// 6. Click "Publish"
// 7. Esperá 10-30 segundos
// ========================================
